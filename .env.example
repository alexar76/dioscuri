# ============================================================================
# DIOSCURI — startup environment. Copy to .env, fill in, never commit.
#
# MINIMAL START = 2 variables:
#   1) one LLM key            (DEEPSEEK_API_KEY — ecosystem default)
#   2) one platform token     (DISCORD_BOT_TOKEN + DISCORD_GUILD_ID,
#                              and/or TELEGRAM_BOT_TOKEN + TELEGRAM_CHAT_ID)
# Everything else is optional: Discord channels/roles/categories are created
# automatically on first boot (idempotent, never deletes anything), Telegram
# gets its command menu + pinned links automatically, the knowledge base
# seeds itself from GitHub, and the content calendar starts on its own.
# ============================================================================

# ---- 1. LLM provider (required; ecosystem default: deepseek) ---------------
# Cloud:  deepseek | anthropic | anthropic-compatible | openai | openai-compatible
# Local:  ollama (:11434) | lmstudio (:1234) | llamacpp (:8080) — keyless,
#         OpenAI-protocol, defaults point at localhost.
DIOSCURI_LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
# ANTHROPIC_API_KEY=               # anthropic / anthropic-compatible
# OPENAI_API_KEY=                  # openai
# DIOSCURI_LLM_API_KEY=            # generic *-compatible key
# DIOSCURI_LLM_MODEL=deepseek-chat
# DIOSCURI_LLM_BASE_URL=           # override endpoint (required for *-compatible)
# DIOSCURI_LLM_TIMEOUT_MS=30000

# Failover: when the primary provider trips its circuit breaker (repeated
# failures), DIOSCURI switches here automatically and probes the primary back.
# Great combo: cloud primary + local fallback (or the reverse).
# DIOSCURI_LLM_FALLBACK_PROVIDER=ollama
# DIOSCURI_LLM_FALLBACK_MODEL=llama3.1
# DIOSCURI_LLM_FALLBACK_BASE_URL=http://localhost:11434/v1

# ---- 2a. Discord (POLLUX — the immortal twin) -------------------------------
# Bot needs: Manage Channels, Manage Roles, Manage Messages, Moderate Members,
# Send Messages, Read Message History + the MESSAGE CONTENT intent (dev portal).
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Auto-created by the provisioner when empty — set only to reuse existing ones:
# DISCORD_ANNOUNCE_CHANNEL_ID=
# DISCORD_MOD_LOG_CHANNEL_ID=
# DISCORD_CANON_CHANNEL_ID=
# DISCORD_GENERAL_CHANNEL_ID=
# DISCORD_AUTOSTRUCTURE=1          # 0 = never touch the server layout

# ---- 2b. Telegram (CASTOR — the mortal twin) --------------------------------
# Bot must be admin of the group/channel for moderation + pinning.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TELEGRAM_AUTOSETUP=1             # 0 = skip command menu / pinned links setup

# ---- AI meme images — optional (enable via images.aiProvider in the JSON) ---
# Provider is chosen in dioscuri.config.json (content.images.aiProvider:
# openai | together | comfyui | local). Secrets live here:
# OPENAI_API_KEY=                  # openai (also reused if set above)
# TOGETHER_API_KEY=                # together (FLUX schnell — cheap)
# DIOSCURI_IMAGE_API_KEY=          # generic override, wins over the two above
# DIOSCURI_IMAGE_BASE_URL=         # required for comfyui (GPU); optional for local (default http://127.0.0.1:8766)
# DIOSCURI_SCREENSHOT_BASE_URL=    # Playwright sidecar for README demo screenshots (default http://127.0.0.1:8767)
#
# Local CPU sidecar (free, ~2–4 min per 512² image):
#   ./scripts/install-local-image.sh && venv-local-image/bin/python scripts/local_image_server.py
#   then set aiProvider: "local" in dioscuri.config.json

# ---- KERYX syndication — optional (post-only, our own accounts) -------------
# Release announcements go to any sink whose secrets are present.
# Bluesky: create an app password at bsky.app -> Settings -> App Passwords.
# BLUESKY_IDENTIFIER=              # e.g. dioscuri.bsky.social
# BLUESKY_APP_PASSWORD=
# Mastodon: create an app token (Settings -> Development), set the bot flag on the profile.
# MASTODON_BASE_URL=               # e.g. https://mastodon.social
# MASTODON_ACCESS_TOKEN=
# X (pay-per-use since 2026-02: ~$0.015/post, $0.20/post with URL) — explicit opt-in:
# X_SYNDICATION=1
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_SECRET=
# dev.to monthly digest article (Settings -> Extensions -> API key):
# DEVTO_API_KEY=

# ---- 2c. HELIOS broadcast (optional, fail-soft) ----------------------------
# Append release-short jobs to shared queue — HELIOS worker ingests on next run.
# HELIOS_SYNDICATION=1
# HELIOS_QUEUE_PATH=/data/helios-queue.jsonl

# ---- 2d. Social stats cache (Alien Monitor) --------------------------------
# Cached member/follower counts exposed on GET /health → social.*
# DIOSCURI_SOCIAL_CACHE_SEC=300
# TWITTER_BEARER_TOKEN=              # or X_BEARER_TOKEN
# TWITTER_USER_ID=                   # or X_USER_ID
# TELEGRAM_CHANNEL_ID=               # for getChatMemberCount (defaults to TELEGRAM_CHAT_ID)

# ---- 3. MNEMOSYNE (GitHub knowledge sync) — optional ------------------------
# Read-only PAT raises GitHub API limits 60/h -> 5000/h. Fine to leave empty.
GITHUB_TOKEN=

# ---- 4. Service — defaults are production-ready -----------------------------
DIOSCURI_HTTP_PORT=8790
DIOSCURI_DATA_DIR=/data
DIOSCURI_LOG_LEVEL=info
# DIOSCURI_CONFIG=dioscuri.config.json   # non-secret tuning (cadence, topics…)
# DIOSCURI_DRY_RUN=1               # run with zero tokens (KB + health only)
# TELEGRAM_DISABLED=1              # keep the twin asleep without unsetting the token
# DISCORD_DISABLED=1
